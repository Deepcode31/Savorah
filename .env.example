# Copy to .env and fill in real values. Never commit .env.

# MongoDB — local Docker/Mongo, or Atlas for production
# Local:  mongodb://127.0.0.1:27017/savorah_app
# Atlas:  mongodb+srv://USER:PASS@cluster.mongodb.net/savorah_app
MONGODB_URI=mongodb://127.0.0.1:27017/savorah_app

# JWT signing secret (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Free OpenRouter model IDs (override if lineup rotates)
OPENROUTER_MODEL_CHAT=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL_JSON=openai/gpt-oss-20b:free
OPENROUTER_MODEL_FAST=meta-llama/llama-3.2-3b-instruct:free
OPENROUTER_MODEL_VISION=google/gemma-4-26b-a4b-it:free

# Public app URL (OpenRouter HTTP-Referer; also used for auth redirects)
# Local:       http://localhost:5055
# Production:  https://your-app.onrender.com  (or your custom domain)
APP_URL=http://localhost:5055

# Server port (macOS often reserves 5000 for AirPlay — use 5055 locally)
PORT=5055

# --- Google Sign-In (optional) ---
# Create an OAuth 2.0 Web client at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins MUST include your APP_URL exactly
# (scheme + host + port — no trailing slash), e.g. http://localhost:5055
# Without GOOGLE_CLIENT_ID, the app falls back to passwordless email-code login.
GOOGLE_CLIENT_ID=

# --- Email OTP delivery (optional) ---
# For Gmail: create an App Password (https://myaccount.google.com/apppasswords)
# and use it as SMTP_PASS. Without SMTP, login codes are printed to the server
# console (dev mode) so the flow still works locally.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
